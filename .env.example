# Required: ChainStream GraphQL API key (X-API-KEY header)
CHAINSTREAM_API_KEY=

# Optional: ChainStream GraphQL endpoint override
# CHAINSTREAM_ENDPOINT=https://graphql.chainstream.io/graphql

# Optional: enables `--reasoning` (Claude AI explanation of each depeg signal)
ANTHROPIC_API_KEY=

# Optional: override the Claude model used by `--reasoning`
# ANTHROPIC_MODEL=claude-opus-4-5
